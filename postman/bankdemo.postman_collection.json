{
  "info": {
    "_postman_id": "a1b2c3d4-bankdemo-api",
    "name": "bankdemo API",
    "description": "REST API for the bankdemo Spring Boot application. Set `baseUrl` if the server is not on localhost:8080.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "userId",
      "value": "1"
    },
    {
      "key": "accountId",
      "value": "1"
    },
    {
      "key": "targetAccountId",
      "value": "2"
    }
  ],
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Create user",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"login\": \"alice\"\n}"
            },
            "url": "{{baseUrl}}/api/users",
            "description": "Creates a user and one starter account. Returns `UserResponse` (201) and `Location: {{baseUrl}}/api/users/{id}`."
          },
          "response": []
        },
        {
          "name": "Get users",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/users",
            "description": "Returns all users with accounts (200)."
          },
          "response": []
        },
        {
          "name": "Get user by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/users/{{userId}}",
            "description": "Returns a single user by id (200)."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Accounts",
      "item": [
        {
          "name": "Create account",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": {{userId}}\n}"
            },
            "url": "{{baseUrl}}/api/accounts",
            "description": "Opens another account for the given user. Returns `AccountResponse` (201) and `Location: {{baseUrl}}/api/accounts/{id}`."
          },
          "response": []
        },
        {
          "name": "Get accounts",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/accounts",
            "description": "Returns all accounts (200)."
          },
          "response": []
        },
        {
          "name": "Get account by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/accounts/{{accountId}}",
            "description": "Returns a single account by id (200)."
          },
          "response": []
        },
        {
          "name": "Deposit v1 (native update)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 100.50\n}"
            },
            "url": "{{baseUrl}}/api/v1/accounts/{{accountId}}/deposit",
            "description": "Deposit via JPQL update (no entity optimistic lock). Returns `AccountResponse` (200)."
          },
          "response": []
        },
        {
          "name": "Deposit v2 (optimistic)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 100.50\n}"
            },
            "url": "{{baseUrl}}/api/v2/accounts/{{accountId}}/deposit",
            "description": "Deposit via load + save (`@Version`). May return 409 on conflict."
          },
          "response": []
        },
        {
          "name": "Withdraw v1 (native update)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 25.00\n}"
            },
            "url": "{{baseUrl}}/api/v1/accounts/{{accountId}}/withdraw",
            "description": "Withdraw via JPQL update. Returns `AccountResponse` (200)."
          },
          "response": []
        },
        {
          "name": "Withdraw v2 (optimistic)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 25.00\n}"
            },
            "url": "{{baseUrl}}/api/v2/accounts/{{accountId}}/withdraw",
            "description": "Withdraw via load + save (`@Version`). May return 409 on conflict."
          },
          "response": []
        },
        {
          "name": "Transfer v1 (pessimistic)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"targetAccountId\": {{targetAccountId}},\n  \"amount\": 50.00\n}"
            },
            "url": "{{baseUrl}}/api/v1/accounts/{{accountId}}/transfer",
            "description": "Transfer with pessimistic row locks. Returns `TransferResponse` (200)."
          },
          "response": []
        },
        {
          "name": "Transfer v2 (optimistic)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"targetAccountId\": {{targetAccountId}},\n  \"amount\": 50.00\n}"
            },
            "url": "{{baseUrl}}/api/v2/accounts/{{accountId}}/transfer",
            "description": "Transfer with optimistic locking (`@Version`). May return 409 on conflict."
          },
          "response": []
        },
        {
          "name": "Close account",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/api/accounts/{{accountId}}",
            "description": "Closes an account; balance is moved to another account of the same user (204)."
          },
          "response": []
        }
      ]
    }
  ]
}
